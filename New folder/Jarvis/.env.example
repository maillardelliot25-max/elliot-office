# ────────────────────────────────────────────────────────────────────────────
# JARVIS ENVIRONMENT CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# Copy this to .env and fill in your credentials
# CRITICAL: Add .env to .gitignore — never commit secrets!


# ──── OWNER IDENTITY ──────────────────────────────────────────────────────────
OWNER_NAME="Your Name"
OWNER_EMAIL="your@email.com"
OWNER_PHONE="+12345678901"                    # E.164 format for Vapi
OWNER_WHATSAPP_NUMBER="12345678901"           # without +, Meta format


# ──── SERVER ──────────────────────────────────────────────────────────────────
PORT=8000
JARVIS_PUBLIC_URL="https://jarvis.railway.app"  # your deployed URL (Railway/Vercel/etc)
IDLE_POLL_SECONDS=15


# ──── AI MODELS ───────────────────────────────────────────────────────────────
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Get key: https://platform.openai.com/api-keys (used for embeddings only)
OPENAI_API_KEY="sk-proj-..."


# ──── MEMORY (PINECONE VECTOR DB) ─────────────────────────────────────────────
# Sign up: https://www.pinecone.io
# Get API key from: Pinecone Console → API Keys
PINECONE_API_KEY="..."
PINECONE_INDEX_NAME="jarvis-memory"


# ──── VOICE (VAPI.AI) ─────────────────────────────────────────────────────────
# Sign up: https://vapi.ai
# After setup, call: POST /vapi/setup to auto-create the assistant
VAPI_API_KEY="..."
VAPI_PHONE_NUMBER_ID="..."
VAPI_ASSISTANT_ID="..."           # Leave blank, will be auto-populated by /vapi/setup


# ──── WHATSAPP (META CLOUD API) ───────────────────────────────────────────────
# 1. Create a Meta Business App: https://developers.facebook.com/
# 2. Set up WhatsApp Cloud API
# 3. Get Phone Number ID and Access Token
WHATSAPP_PHONE_NUMBER_ID="..."
WHATSAPP_ACCESS_TOKEN="..."
WHATSAPP_VERIFY_TOKEN="jarvis-verify-2026"    # custom verification string


# ──── GMAIL (GOOGLE OAUTH2) ───────────────────────────────────────────────────
# SETUP GUIDE:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project
# 3. Enable Gmail API
# 4. Create OAuth 2.0 credentials (Desktop app)
# 5. Authorization scope: https://www.googleapis.com/auth/gmail.modify
# 6. Run local Jarvis to get consent URL, click it, copy refresh token
#
# After setup, you'll have these:
GMAIL_CLIENT_ID="...apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="..."
GMAIL_ACCESS_TOKEN="ya29...."        # obtained via OAuth flow
GMAIL_REFRESH_TOKEN="1//..."         # keep this safe; allows auto-refresh


# ──── LINKEDIN (OAUTH2) ───────────────────────────────────────────────────────
# SETUP GUIDE:
# 1. Create a LinkedIn App: https://www.linkedin.com/developers/apps
# 2. Request "Sign In with LinkedIn" + "Share on LinkedIn" permissions
# 3. Use OAuth redirect to get access token
#
LINKEDIN_CLIENT_ID="..."
LINKEDIN_CLIENT_SECRET="..."
LINKEDIN_ACCESS_TOKEN="..."


# ──── GITHUB (AUTONOMOUS DEPLOYMENT) ──────────────────────────────────────────
# SETUP GUIDE:
# 1. Go to https://github.com/settings/tokens
# 2. Create Personal Access Token (classic)
# 3. Scopes: repo, workflow, admin:repo_hook
# 4. Copy the token (only shown once!)
#
GITHUB_TOKEN="ghp_..."
GITHUB_USERNAME="your-github-handle"


# ──── VERCEL (DEPLOYMENT PLATFORM) ────────────────────────────────────────────
# SETUP GUIDE:
# 1. Sign up: https://vercel.com
# 2. Go to https://vercel.com/account/tokens
# 3. Create a token with scope: full
#
VERCEL_TOKEN="..."


# ──── BOOKKEEPING (PLAID FINANCIAL API) ──────────────────────────────────────
# SETUP GUIDE:
# 1. Sign up: https://plaid.com
# 2. Get Client ID + Secret from Plaid dashboard
# 3. Set up Plaid Link in Jarvis frontend to get ACCESS_TOKEN
#    (User connects their bank, you get the token)
#
PLAID_CLIENT_ID="..."
PLAID_SECRET="..."
PLAID_ACCESS_TOKEN="access-sandbox-..."   # from Plaid Link flow


# ────────────────────────────────────────────────────────────────────────────
# NOTES:
# ────────────────────────────────────────────────────────────────────────────
# - Start with CRITICAL credentials (top of this file)
# - Fill in integrations incrementally (voice, then WhatsApp, then email, etc.)
# - Test each integration with: curl localhost:8000/health
# - For production: use Railway/Vercel environment variables, not .env files
# - Never commit .env to git — add to .gitignore
