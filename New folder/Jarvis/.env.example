# ============================================================
# JARVIS FREE EDITION — Environment Variables
# Copy to .env, fill in values, NEVER commit to git
# ============================================================

# ── YOU ─────────────────────────────────────────────────────
OWNER_NAME=Elliot
OWNER_EMAIL=your@email.com
OWNER_WHATSAPP_NUMBER=3386333

# ── TELEGRAM (Primary channel — zero restrictions) ──────────
# Step 1: Telegram → @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=
# Step 2: Send bot a message, open:
#   https://api.telegram.org/botYOUR_TOKEN/getUpdates
#   Copy the "id" number inside "from"
TELEGRAM_CHAT_ID=

# ── CLAUDE (Brain — reasoning, code, vision) ─────────────────
# https://console.anthropic.com → API Keys → Create Key
# Starts with: sk-ant-...
# Cost: pennies per day, ~$3-5/month for heavy use
ANTHROPIC_API_KEY=

# ── GOOGLE (Nanobanana images + Veo 3.1 videos) ─────────────
# https://aistudio.google.com → Get API key → Create API key
# Same key for BOTH image generation and video generation
# Nano Banana 2 = gemini-3.1-flash-image-preview (latest, fast)
# Nano Banana Pro = gemini-3-pro-image-preview (best quality)
# Veo 3.1 = veo-3.0-generate-preview ($0.75/sec video)
# New Google accounts get $300 free credit
GOOGLE_API_KEY=

# ── GITHUB (Auto-deploy code) ────────────────────────────────
# https://github.com/settings/tokens → New token (classic)
# Scopes to check: repo, workflow
GITHUB_TOKEN=
GITHUB_USERNAME=

# ── WHATSAPP (Add once Meta unlocks your account) ────────────
# Phone Number ID is already saved — just need the token
# Token: developers.facebook.com → your app → WhatsApp → Getting Started
WHATSAPP_PHONE_NUMBER_ID=880684635006473
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=jarvis-verify-2026

# ── GMAIL (Optional — email reading/replying) ────────────────
# https://console.cloud.google.com → Enable Gmail API → OAuth credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── SERVER ──────────────────────────────────────────────────
PORT=8000
IDLE_POLL_SECONDS=10
CHROMA_PERSIST_DIR=./jarvis_memory
