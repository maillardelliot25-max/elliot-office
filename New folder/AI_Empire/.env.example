# AI Empire – Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ===================== SERVER =====================
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# Frontend URL for CORS (use * for dev, specific domain in production)
FRONTEND_URL=*

# Timezone for cron scheduler
TZ=America/New_York

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ===================== AUTH =====================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-64-character-random-string-in-production
REFRESH_SECRET=change-this-refresh-secret-too

JWT_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=7d

# ===================== DATABASE =====================
# Leave empty to run in in-memory mode (no data persistence)
MONGO_URI=mongodb://127.0.0.1:27017/ai_empire
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/ai_empire

# ===================== AI / OPENAI =====================
# Required for: AI message generation, proposal writing, content creation, insights
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===================== LINKEDIN =====================
# Create app at: https://linkedin.com/developers
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback

# ===================== TWITTER / X =====================
# Get from: https://developer.twitter.com
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# ===================== UPWORK =====================
# Apply at: https://developers.upwork.com
UPWORK_API_KEY=your-upwork-api-key
UPWORK_API_SECRET=your-upwork-api-secret

# ===================== NOTIFICATIONS =====================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url
ALERT_EMAIL=alerts@yourdomain.com

# ===================== STRIPE (for AI SaaS apps) =====================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===================== REVENUE TARGET =====================
MONTHLY_REVENUE_TARGET=10000
