# Maillard AI — Elliot Maillard's Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ===================== SERVER =====================
PORT=3000
NODE_ENV=development
HOST=0.0.0.0
FRONTEND_URL=*
TZ=America/New_York
LOG_LEVEL=info

# ===================== OWNER =====================
OWNER_NAME=Elliot Maillard
OWNER_EMAIL=elliot@maillard.ai
OWNER_BRAND=Maillard AI

# ===================== AUTH =====================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-64-character-random-string-in-production
REFRESH_SECRET=change-this-refresh-secret-too
JWT_EXPIRES_IN=30d
REFRESH_EXPIRES_IN=365d

# ===================== DATABASE =====================
# Leave empty to run in in-memory mode (no data persistence)
# MONGO_URI=mongodb://127.0.0.1:27017/maillard_ai
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/maillard_ai

# ===================== AI / OPENAI =====================
# Powers: AI proposal writing, message generation, content creation, insights
# Get key at: platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===================== REVENUE TARGET =====================
MONTHLY_REVENUE_TARGET=10000

# ===================== PAYMENT WEBHOOKS =====================
# These fire when you get paid — updates dashboard automatically

# PayPal: developer.paypal.com → Apps → Webhooks
# Webhook URL: https://YOUR_SERVER/webhooks/paypal
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Wise: wise.com → Settings → Developer tools → Webhooks
# Webhook URL: https://YOUR_SERVER/webhooks/wise
WISE_WEBHOOK_SECRET=your-wise-webhook-secret

# Gumroad: app.gumroad.com → Settings → Advanced → Ping URL
# Webhook URL: https://YOUR_SERVER/webhooks/gumroad
# (Gumroad doesn't use a secret — IP verification only)

# LemonSqueezy: app.lemonsqueezy.com → Settings → Webhooks
# Webhook URL: https://YOUR_SERVER/webhooks/lemonsqueezy
LEMONSQUEEZY_WEBHOOK_SECRET=your-lemonsqueezy-signing-secret

# Stripe (when you sign up): dashboard.stripe.com → Developers → Webhooks
# Webhook URL: https://YOUR_SERVER/webhooks/stripe
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===================== LINKEDIN OUTREACH =====================
# LinkedIn official API (read-only for individuals)
# Create app: linkedin.com/developers
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# For real outreach automation, use Phantombuster or Waalaxy instead:
# Phantombuster: $59/mo at phantombuster.com
# Waalaxy: $40/mo at waalaxy.com
PHANTOMBUSTER_API_KEY=your-phantombuster-api-key

# ===================== TWITTER / X =====================
# developer.twitter.com → Project → App → Keys and tokens
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# ===================== UPWORK =====================
# Apply at: developers.upwork.com (approval required)
UPWORK_API_KEY=your-upwork-api-key
UPWORK_API_SECRET=your-upwork-api-secret

# ===================== FREELANCE PLATFORMS =====================
# These are for monitoring — actual bidding is done manually via the platforms
# Fiverr: fiverr.com/selling
FIVERR_USERNAME=elliotmaillard

# PeoplePerHour: peopleperhour.com
PPH_USERNAME=elliotmaillard

# Guru: guru.com
GURU_USERNAME=elliotmaillard

# Bark: bark.com/become-a-pro
BARK_API_KEY=your-bark-api-key

# ===================== DIGITAL PRODUCT PLATFORMS =====================
# Gumroad: gumroad.com
GUMROAD_ACCESS_TOKEN=your-gumroad-access-token

# LemonSqueezy: lemonsqueezy.com
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id

# ===================== NOTIFICATIONS =====================
# Slack: api.slack.com → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# Discord: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url
ALERT_EMAIL=elliot@maillard.ai

# ===================== VIRTUAL PHONE (Twilio) =====================
# For SMS verification on platforms: twilio.com
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
